{
  "name": "Facturo API",
  "image": "mcr.microsoft.com/devcontainers/java:1-21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    }
  },
  "postCreateCommand": "chmod +x mvnw && docker compose -f docker-compose.yml up -d && sleep 4 && ./mvnw -q -DskipTests compile",
  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "API Spring Boot",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "humao.rest-client"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic"
      }
    }
  }
}
