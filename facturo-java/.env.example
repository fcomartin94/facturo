# Copia a .env si usas herramientas que lo carguen, o exporta en la shell.
# Spring Boot lee estas variables directamente (no hace falta archivo .env por defecto).

# JWT: clave en Base64, mínimo 256 bits para HS256 (genera una nueva en producción).
# Ejemplo: echo -n "mi-clave-secreta-larga-al-menos-32-chars!!" | base64
FACTURO_JWT_SECRET=c2VjcmV0LWtleS1tdXktbGFyZ2EtcGFyYS1qd3QtZmFjdHVybw==

# Opcional: caducidad del token en ms (por defecto 86400000 = 24h)
# FACTURO_JWT_EXPIRATION_MS=86400000

# PostgreSQL (por defecto coinciden con docker-compose.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/facturo_db
SPRING_DATASOURCE_USERNAME=facturo_user
SPRING_DATASOURCE_PASSWORD=facturo_pass
