{
	"name": "facturo/facturo-php",
	"description": "Plataforma de facturación para autónomos - PHP bare-metal",
	"type": "project",
	"require": {
		"php": ">=8.2",
		"lcobucci/jwt": "^5.0",
		"dompdf/dompdf": "^2.0",
		"vlucas/phpdotenv": "^5.6"
	},
	"autoload": {
		"psr-4": {
			"Facturo\\": "src/"
		}
	},
	"config": {
		"optimize-autoloader": true
	}
}