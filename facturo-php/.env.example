# ── Entorno ────────────────────────────────────────────────
# development → muestra errores reales en la respuesta JSON
# production  → oculta errores internos (usar en producción)
APP_ENV=development

# ── Base de datos ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=facturo_db
DB_USER=facturo_user
DB_PASS=facturo_pass

# ── JWT ─────────────────────────────────────────────────────
# Generar clave con: openssl rand -base64 32
JWT_SECRET=CAMBIA_ESTO_openssl_rand_base64_32
# Tiempo de expiración del token en segundos (86400 = 24 horas)
JWT_EXPIRATION=86400
